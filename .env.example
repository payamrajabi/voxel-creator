# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real keys. Set the same values in
# your Vercel project (Settings → Environment Variables) so production works too.

# --- Neon (Postgres): server-side character storage ---
# Vercel → your project → Storage → Create Database → Neon. It sets this for you;
# pull it locally with `vercel env pull .env.local`. Or grab the connection string
# from the Neon dashboard (neon.tech) and paste it here.
DATABASE_URL=

# --- Clerk (authentication) ---
# https://dashboard.clerk.com → your app → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
